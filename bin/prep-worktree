#!/bin/bash
# Prepares a worktree by creating a .venv and installing the project.
# Usage: prep-worktree [worktree-path]
# Runs silently in the background — check the log file for status.

set -eo pipefail

WORKTREE_PATH="${1:-$(pwd)}"
WORKTREE_PATH="$(cd "$WORKTREE_PATH" && pwd)"

BUILD_LOG="/tmp/prep-worktree-$(basename "$WORKTREE_PATH").log"

(
  cd "$WORKTREE_PATH" &&
  # macOS: .claude/ has the UF_HIDDEN flag, which new files inherit.
  # Python 3.14 skips hidden .pth files, breaking editable installs.
  chflags -R nohidden "$WORKTREE_PATH" 2>/dev/null || true &&
  if [ ! -d "$WORKTREE_PATH/.venv" ]; then
    python3 -m venv --upgrade-deps .venv
  fi &&
  .venv/bin/pip install -q -e ".[dev]"
) > "$BUILD_LOG" 2>&1 </dev/null &
disown 2>/dev/null || true
